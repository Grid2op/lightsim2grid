@PACKAGE_INIT@

# Include directory — path computed relative to this config file's installed location
set_and_check(lightsim2grid_core_INCLUDE_DIR "@PACKAGE_LS2G_INSTALL_INCLUDEDIR@")

# Import the library target (lightsim2grid::core)
if(NOT TARGET lightsim2grid::core)
    include("${CMAKE_CURRENT_LIST_DIR}/lightsim2grid_coreTargets.cmake")
endif()

# Convenience alias so users can also write ls2g::core
if(NOT TARGET ls2g::core AND TARGET lightsim2grid::core)
    add_library(ls2g::core ALIAS lightsim2grid::core)
endif()

set(lightsim2grid_core_LIBRARIES    lightsim2grid::core)
set(lightsim2grid_core_INCLUDE_DIRS "${lightsim2grid_core_INCLUDE_DIR}")

check_required_components(lightsim2grid_core)
